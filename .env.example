# api.slack.com/apps > 対象アプリ > Basic Information から取得
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=

# デプロイ先のURL（末尾スラッシュなし）例: https://slack-status-signal.onrender.com
BASE_URL=

# 外部cron（cron-job.org等）から /trigger を叩く際に使う合言葉。適当な長いランダム文字列にする
TRIGGER_SECRET=change-me-to-a-long-random-string

PORT=3000

# ここに書いたメールアドレスの人だけ登録できる（カンマ区切り、例: shohei@example.com,tanaka@example.com）
# 空にすると誰でも登録できてしまうので、必ず設定してください
ALLOWED_EMAILS=mitsuhiro.yoshida@yappli.co.jp

# ある期間だけBotを動かしたい場合に設定（Asia/Tokyo基準、YYYY-MM-DD）。空欄なら期間制限なし
BOT_START_DATE=
BOT_END_DATE=
